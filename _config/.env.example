# Config keys — copy ke _config/.env dan isi nilainya
# File ini BOLEH masuk repo. File .env TIDAK BOLEH masuk repo.

APP_ENV=production
APP_DEBUG=false
APP_KEY=

DB_DSN=sqlite:_storage/database.sqlite
DB_USER=
DB_PASS=

LOG_LEVEL=warning
LOG_RETENTION_DAYS=30

SESSION_SALT=

# Comma-separated list of trusted proxy IPs (Cloudflare, Nginx, load balancer).
# ip() hanya trust CF-Connecting-IP / X-Forwarded-For kalau REMOTE_ADDR ada di sini.
# Contoh: TRUSTED_PROXIES=103.21.244.0,103.22.200.0
TRUSTED_PROXIES=

# Direktori penyimpanan file rate limiter (fallback kalau APCu tidak tersedia).
# Kosongkan untuk default ke sys_get_temp_dir()/rate_guard.
RATE_GUARD_FILE_DIR=
